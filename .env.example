# Copy to .env and fill in real values. .env is gitignored.

# Postgres — used by docker-compose and the Ktor server
DB_USER=respublika_admin
DB_PASSWORD=change-me
DB_NAME=respublika_db

# JDBC URL the server uses to reach Postgres. Default targets the docker-compose
# service name; override if you run Postgres elsewhere.
# DB_JDBC_URL=jdbc:postgresql://respublika-db:5432/respublika_db

# JWT signing secret. Generate with: openssl rand -hex 32
JWT_SECRET=change-me
